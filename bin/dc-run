#!/usr/bin/env bash

set -euo pipefail

# shellcheck source=./docker-compose-env.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/docker-compose-env.sh"

joined_args=" $* "
if [[ -n "${BTR_WORKTREE_DB_SUFFIX:-}" ]] && [[ "$joined_args" == *" rspec "* || "$joined_args" == *" RAILS_ENV=test "* ]]; then
  echo "Worktree test runs require prepared suffixed databases for ${BTR_WORKTREE_DB_SUFFIX}." >&2
  echo "Run test database prep before full-suite worktree RSpec runs." >&2
fi

./bin/dc run --rm --no-deps app "$@"
