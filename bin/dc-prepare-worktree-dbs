#!/usr/bin/env bash

set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

# shellcheck source=./docker-compose-env.sh
source "$repo_root/bin/docker-compose-env.sh"

if [[ -z "${NLO_WORKTREE_DB_SUFFIX:-}" ]]; then
  exit 0
fi

./bin/dc run --rm --no-deps app bundle exec rails db:create
./bin/dc run --rm --no-deps app bundle exec rails db:prepare
./bin/dc run --rm --no-deps -e RAILS_ENV=test app bundle exec rails db:create
./bin/dc run --rm --no-deps -e RAILS_ENV=test app bundle exec rails db:prepare
